---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  headings: { depth: number; slug: string; text: string }[];
  related: CollectionEntry<'articles'>[];
}

const { article, headings, related } = Astro.props;
const { title, seoTitle, seoDescription, category, keyword, publishDate } = article.data;

const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
const readingTime = Math.ceil(
  (article.body?.split(/\s+/).length ?? 0) / 200
);
const dateFormatted = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
}).format(publishDate);

const categoryLabel = category === 'running' ? 'Running' : 'Comparativas';
const categoryHref = `/${category}/`;
const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: seoDescription,
  author: { '@type': 'Organization', name: 'Equipo GuíaDeportiva' },
  publisher: {
    '@type': 'Organization',
    name: 'GuíaDeportiva.es',
    url: 'https://guiadeportiva.es',
  },
  datePublished: publishDate.toISOString(),
  dateModified: publishDate.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.href },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://guiadeportiva.es/' },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: `https://guiadeportiva.es${categoryHref}` },
    { '@type': 'ListItem', position: 3, name: title, item: Astro.url.href },
  ],
};
---
<Layout title={seoTitle} description={seoDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="progress" id="progress" aria-hidden="true"></div>

  <!-- Article header -->
  <div class="art-head">
    <div class="wrap">
      <nav class="crumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span class="sep">/</span>
        <a href={categoryHref}>{categoryLabel}</a>
        <span class="sep">/</span>
        <span class="cur">{title}</span>
      </nav>
      <div class="art-head-inner">
        <div class="art-tags">
          <a href={categoryHref} class="tag">{categoryLabel}</a>
          <span style="font-family:var(--mono);font-size:12.5px;color:var(--ink-faint);">
            Guía de compra · Actualizada
          </span>
        </div>
        <h1>{title}</h1>
        <div class="byline">
          <div class="author">
            <span class="avatar" aria-hidden="true"></span>
            <div>
              <div class="nm">Equipo GuíaDeportiva</div>
              <div class="rl">Editores de running</div>
            </div>
          </div>
          <span class="vrule" aria-hidden="true"></span>
          <div class="meta">
            <span>Actualizado {dateFormatted}</span>
            <span>·</span>
            <span>{readingTime} min de lectura</span>
          </div>
        </div>
        <div class="disclosure">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11 12h1v4h1"/>
          </svg>
          <div>
            <b>Transparencia:</b> esta guía contiene enlaces de afiliado. Si compras a través
            de ellos podemos llevarnos una pequeña comisión, sin coste extra para ti. Nadie
            nos paga por aparecer aquí ni condiciona nuestras notas.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Article body -->
  <div class="wrap">
    <div class="art-grid">
      <!-- TOC sidebar -->
      {tocItems.length > 0 && (
        <aside class="toc" aria-label="Índice del artículo">
          <h4>En esta guía</h4>
          <ul id="toc-list">
            {tocItems.map(h => (
              <li>
                <a href={`#${h.slug}`} class={h.depth === 3 ? 'toc-h3' : ''}>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
          <div class="share">
            <h4>Compartir</h4>
            <div class="share-btns">
              <button
                id="btn-x"
                aria-label="Compartir en X"
                data-url={Astro.url.href}
                data-title={title}
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 2h3l-7 8 8 12h-6l-5-7-6 7H2l8-9L2 2h6l4 6 6-6z"/>
                </svg>
              </button>
              <button
                id="btn-wa"
                aria-label="Compartir en WhatsApp"
                data-url={Astro.url.href}
                data-title={title}
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 5-1.3A10 10 0 1 0 12 2zm4.5 13.1c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1l-.7.9c-.1.2-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.1-.2 0-.4.1-.5l.4-.5.2-.4v-.4l-.7-1.7c-.2-.5-.4-.4-.6-.4h-.4a1 1 0 0 0-.7.3 2.8 2.8 0 0 0-.9 2.1c0 1.3.9 2.5 1 2.7.1.2 1.9 2.9 4.6 4 .6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1l-.4-.2z"/>
                </svg>
              </button>
              <button id="btn-copy" aria-label="Copiar enlace" data-url={Astro.url.href}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 14a4 4 0 0 0 6 .5l2-2a4 4 0 0 0-6-6l-1 1"/>
                  <path d="M15 10a4 4 0 0 0-6-.5l-2 2a4 4 0 0 0 6 6l1-1"/>
                </svg>
              </button>
            </div>
          </div>
        </aside>
      )}

      <!-- Prose content -->
      <article class="prose">
        <slot />
        <!-- Author bio -->
        <div class="bio">
          <span class="avatar" aria-hidden="true"></span>
          <div>
            <div class="b-name">Equipo GuíaDeportiva</div>
            <div class="b-role">Editores de running en GuíaDeportiva.es</div>
            <p>
              Nuestro equipo analiza cada zapatilla en condiciones reales: rodajes largos,
              series en pista y más de 800 km de pruebas acumuladas. Independientes, sin
              patrocinios de marca.
            </p>
          </div>
        </div>
      </article>
    </div>
  </div>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="related">
      <div class="wrap">
        <div class="sec-head">
          <span class="eyebrow">Sigue leyendo</span>
          <h2>Guías relacionadas</h2>
        </div>
        <div class="rel-grid">
          {related.map(r => (
            <a href={`/${r.slug}/`} class="rel-card">
              <div class="r-img">
                <span>foto · guía</span>
              </div>
              <div class="r-body">
                <span class="tag">{r.data.category === 'running' ? 'Running' : 'Comparativas'}</span>
                <h3>{r.data.title}</h3>
                <div class="r-meta">
                  {new Intl.DateTimeFormat('es-ES', { month: 'short', year: 'numeric' }).format(r.data.publishDate)}
                  {' · '}
                  {Math.ceil((r.body?.split(/\s+/).length ?? 0) / 200)} min
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<script>
  // Reading progress bar
  const progress = document.getElementById('progress');
  if (progress) {
    const onScroll = () => {
      const h = document.documentElement;
      const pct = h.scrollTop / (h.scrollHeight - h.clientHeight);
      progress.style.width = (pct * 100) + '%';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Active TOC link tracking
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('#toc-list a'));
  if (tocLinks.length) {
    const ids = tocLinks.map(a => a.getAttribute('href')?.slice(1)).filter(Boolean) as string[];
    const sections = ids.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    const onScrollToc = () => {
      let current = sections[0];
      for (const s of sections) {
        if (s.getBoundingClientRect().top <= 130) current = s;
      }
      tocLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + current?.id));
    };
    window.addEventListener('scroll', onScrollToc, { passive: true });
    onScrollToc();
  }

  // Share buttons
  document.getElementById('btn-x')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const url = encodeURIComponent(btn.dataset.url ?? '');
    const text = encodeURIComponent(btn.dataset.title ?? '');
    window.open(`https://twitter.com/intent/tweet?url=${url}&text=${text}`, '_blank');
  });
  document.getElementById('btn-wa')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const url = encodeURIComponent(btn.dataset.url ?? '');
    const text = encodeURIComponent(btn.dataset.title ?? '');
    window.open(`https://wa.me/?text=${text}%20${url}`, '_blank');
  });
  document.getElementById('btn-copy')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(btn.dataset.url ?? '').catch(() => {});
    btn.title = '¡Copiado!';
    setTimeout(() => { btn.title = ''; }, 2000);
  });
</script>
