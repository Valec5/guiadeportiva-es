---
import Layout from '../components/Layout.astro';
---
<Layout
  title="Contacto — GuíaDeportiva.es"
  description="Contacta con el equipo de GuíaDeportiva.es para preguntas, sugerencias o errores en nuestras guías."
  noIndex={true}
>
  <div class="page-head">
    <div class="wrap">
      <nav class="crumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span class="sep">/</span>
        <span class="cur">Contacto</span>
      </nav>
      <h1 style="font-family:var(--serif);font-weight:800;font-size:clamp(30px,4.5vw,50px);letter-spacing:-0.025em;line-height:1.06;margin-top:22px;">
        Contacto
      </h1>
    </div>
  </div>
  <div class="page-content">
    <div class="wrap">
      <div class="prose" style="max-width:560px;">
        <p>
          ¿Tienes alguna pregunta, sugerencia o encontraste un error en alguna de nuestras
          guías? Escríbenos y te respondemos en menos de 48 horas.
        </p>

        <form
          name="contacto"
          method="POST"
          data-netlify="true"
          style="margin-top:32px;display:flex;flex-direction:column;gap:18px;"
        >
          <div>
            <label for="nombre" style="display:block;font-family:var(--mono);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:8px;">
              Nombre
            </label>
            <input
              type="text" id="nombre" name="nombre" required
              style="width:100%;padding:12px 14px;border:1.5px solid var(--line);border-radius:8px;font-family:var(--sans);font-size:15px;color:var(--ink);background:var(--paper);outline:none;transition:border-color .15s;"
              onfocus="this.style.borderColor='var(--orange)'"
              onblur="this.style.borderColor='var(--line)'"
            />
          </div>
          <div>
            <label for="email" style="display:block;font-family:var(--mono);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:8px;">
              Email
            </label>
            <input
              type="email" id="email" name="email" required
              style="width:100%;padding:12px 14px;border:1.5px solid var(--line);border-radius:8px;font-family:var(--sans);font-size:15px;color:var(--ink);background:var(--paper);outline:none;transition:border-color .15s;"
              onfocus="this.style.borderColor='var(--orange)'"
              onblur="this.style.borderColor='var(--line)'"
            />
          </div>
          <div>
            <label for="mensaje" style="display:block;font-family:var(--mono);font-size:12px;letter-spacing:0.06em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:8px;">
              Mensaje
            </label>
            <textarea
              id="mensaje" name="mensaje" rows="5" required
              style="width:100%;padding:12px 14px;border:1.5px solid var(--line);border-radius:8px;font-family:var(--sans);font-size:15px;color:var(--ink);background:var(--paper);outline:none;transition:border-color .15s;resize:vertical;"
              onfocus="this.style.borderColor='var(--orange)'"
              onblur="this.style.borderColor='var(--line)'"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary" style="align-self:flex-start;">
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
