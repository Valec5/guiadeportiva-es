---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';

const articles = await getCollection('articles', a => a.data.category === 'comparativas');
articles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---
<Layout
  title="Comparativas de Zapatillas Running — GuíaDeportiva.es"
  description="Comparativas directas entre los mejores modelos de zapatillas running: datos reales, pruebas en calle y veredicto claro."
>
  <div class="cat-archive-head">
    <div class="wrap">
      <nav class="crumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span class="sep">/</span>
        <span class="cur">Comparativas</span>
      </nav>
      <div style="margin-top:24px;">
        <span class="eyebrow">{articles.length} comparativas</span>
        <h1 style="font-family:var(--serif);font-weight:800;font-size:clamp(34px,5vw,56px);letter-spacing:-0.025em;line-height:1.04;margin-top:14px;">
          Comparativas
        </h1>
        <p style="font-size:clamp(16px,1.6vw,19px);color:var(--ink-soft);margin-top:14px;max-width:56ch;line-height:1.6;">
          Cara a cara entre los modelos más populares del mercado. Datos objetivos, pruebas
          reales y un veredicto claro para que no tengas que dudar.
        </p>
      </div>
    </div>
  </div>

  <div class="wrap" style="padding-top:clamp(40px,6vw,64px);padding-bottom:clamp(56px,7vw,88px);">
    {articles.length > 0 ? (
      <div class="posts-grid">
        {articles.map(art => {
          const readingTime = Math.ceil((art.body?.split(/\s+/).length ?? 0) / 200);
          const dateStr = new Intl.DateTimeFormat('es-ES', { month: 'short', year: 'numeric' }).format(art.data.publishDate);
          return (
            <article class="post-card">
              <a href={`/${art.slug}/`} tabindex="-1" aria-hidden="true">
                <div class="pc-img"></div>
              </a>
              <div class="pc-body">
                <span class="tag">Comparativas</span>
                <h2 class="post-card-title">
                  <a href={`/${art.slug}/`}>{art.data.title}</a>
                </h2>
                {art.data.excerpt && <p class="pc-excerpt">{art.data.excerpt}</p>}
                <div class="pc-meta">
                  <span>{dateStr}</span>
                  <span>·</span>
                  <span>{readingTime} min</span>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <p style="color:var(--ink-soft);font-size:17px;padding:40px 0;">
        No hay comparativas publicadas todavía.
      </p>
    )}
  </div>
</Layout>

<style>
.post-card-title { font-family:var(--serif);font-weight:600;font-size:19px;letter-spacing:-0.01em;line-height:1.22;color:var(--ink); }
.post-card-title a { color:inherit; }
.post-card:hover .post-card-title { color:var(--orange); }
</style>
